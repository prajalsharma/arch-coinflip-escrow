# ---- SECRETS: never commit these ----
# arch_sdk's with_secret_key_file() writes RAW PRIVATE KEYS to these files.
# Committing one lets anyone drain the corresponding account.
.program.json
.authority.json
*-keypair.json
*.key
.env
.env.*
!.env.example

